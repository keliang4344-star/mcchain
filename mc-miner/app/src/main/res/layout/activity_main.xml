<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MC公链 手机矿工"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView android:id="@+id/tvBuild"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="构建: -"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginBottom="12dp" />

        <TextView android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="初始化中..."
            android:textSize="14sp"
            android:padding="12dp"
            android:background="#F5F5F5"
            android:layout_marginBottom="12dp" />

        <TextView android:id="@+id/tvAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="地址: 加载中"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <TextView android:id="@+id/tvMnemonic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="助记词: 生成中..."
            android:textSize="12sp"
            android:textIsSelectable="true"
            android:padding="8dp"
            android:background="#FFF8E1"
            android:layout_marginBottom="8dp" />

        <Button android:id="@+id/btnBackup"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="复制助记词"
            android:backgroundTint="#9C27B0"
            android:layout_marginBottom="8dp" />

        <Button android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="重新生成钱包（清空旧）"
            android:backgroundTint="#F44336"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <TextView android:id="@+id/tvBalance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="余额: 0 umc"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <Button android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="开始挖矿"
            android:backgroundTint="#4CAF50"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <Button android:id="@+id/btnRefresh"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="刷新余额"
            android:backgroundTint="#2196F3"
            android:layout_marginBottom="8dp" />

        <TextView android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="日志:\n"
            android:textSize="11sp"
            android:typeface="monospace"
            android:padding="8dp"
            android:background="#E8E8E8"
            android:minHeight="200dp"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <EditText android:id="@+id/etNodeUrl"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:hint="节点地址:端口"
                android:text="192.168.1.100:26657"
                android:textSize="12sp"
                android:padding="4dp" />

            <Button android:id="@+id/btnConnect"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="连接"
                android:backgroundTint="#FF9800"
                android:textSize="12sp" />
        </LinearLayout>

        </LinearLayout>

        <!-- WebView 容器：必须挂到界面上，否则 evaluateJavascript 在部分 ROM 会直接崩 -->
        <FrameLayout
            android:id="@+id/webHost"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
    </ScrollView>
